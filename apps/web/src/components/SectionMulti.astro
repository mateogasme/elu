---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';
import InlineCode from './InlineCode.astro';

const astroCode = `<Elu.Root name="tags" multiple>
  <Elu.Trigger>
    <Elu.Value placeholder="Pick tags" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="design">
        <Elu.ItemText>Design</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="eng">
        <Elu.ItemText>Engineering</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="ops">
        <Elu.ItemText>Operations</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="sales">
        <Elu.ItemText>Sales</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;

const reactCode = `<Elu.Root name="tags" multiple>
  <Elu.Trigger>
    <Elu.Value placeholder="Pick tags" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="design">
        <Elu.ItemText>Design</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="eng">
        <Elu.ItemText>Engineering</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="ops">
        <Elu.ItemText>Operations</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="sales">
        <Elu.ItemText>Sales</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;

const svelteCode = `<script lang="ts">
  import { Elu } from '@mgasme/elu-svelte';
  let tags: string[] = [];
</script>

<Elu.Root name="tags" multiple bind:value={tags}>
  <Elu.Trigger>
    <Elu.Value placeholder="Pick tags" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="design">
        <Elu.ItemText>Design</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="eng">
        <Elu.ItemText>Engineering</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="ops">
        <Elu.ItemText>Operations</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="sales">
        <Elu.ItemText>Sales</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;

const vueCode = `<Elu.Root name="tags" multiple>
  <Elu.Trigger>
    <Elu.Value placeholder="Pick tags" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="design">
        <Elu.ItemText>Design</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="eng">
        <Elu.ItemText>Engineering</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="ops">
        <Elu.ItemText>Operations</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="sales">
        <Elu.ItemText>Sales</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;
---

<section id="multi">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Multi-select</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">Add the <InlineCode>multiple</InlineCode> prop. Selecting an item toggles it and keeps the menu open.</p>
  <div class="flex items-center justify-center py-6 px-4 rounded-[6px] bg-[var(--page-demo-bg)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root name="tags" multiple>
      <Elu.Trigger><Elu.Value placeholder="Pick tags" /></Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          <Elu.Item value="design"><Elu.ItemText>Design</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="eng"><Elu.ItemText>Engineering</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="ops"><Elu.ItemText>Operations</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="sales"><Elu.ItemText>Sales</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock codes={{ astro: astroCode, react: reactCode, vue: vueCode, svelte: svelteCode }} />
</section>

---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';

const code = `<Elu.Root name="tags" multiple>
  <Elu.Trigger>
    <Elu.Value placeholder="Pick tags" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="design"><Elu.ItemText>Design</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
      <Elu.Item value="eng"><Elu.ItemText>Engineering</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
      <Elu.Item value="ops"><Elu.ItemText>Operations</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;
---

<section id="multi">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Multi-select</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">Add the <code class="font-[var(--font-mono)] text-[13px] px-[5px] py-0.5 rounded-[5px] bg-[var(--page-card-2)] shadow-[0_0_0_1px_var(--page-border)]">multiple</code> prop. Selecting an item keeps the menu open and toggles the value.</p>
  <div class="flex items-start py-6 px-4 rounded-[6px] bg-[var(--page-card-2)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root name="tags" multiple>
      <Elu.Trigger><Elu.Value placeholder="Pick tags" /></Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          <Elu.Item value="design"><Elu.ItemText>Design</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="eng"><Elu.ItemText>Engineering</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="ops"><Elu.ItemText>Operations</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="sales"><Elu.ItemText>Sales</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock code={code} lang="astro" />
</section>

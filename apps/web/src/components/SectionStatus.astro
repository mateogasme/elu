---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';
import InlineCode from './InlineCode.astro';

const statuses = [
  { value: 'backlog',     label: 'Backlog' },
  { value: 'todo',        label: 'Todo' },
  { value: 'in_progress', label: 'In Progress' },
  { value: 'in_review',   label: 'In Review' },
  { value: 'done',        label: 'Done' },
  { value: 'canceled',    label: 'Canceled' },
];

const code = `<Elu.Root id="status" class="status-select" defaultValue="in_progress">
  <Elu.Trigger>
    <span class="dot" aria-hidden="true"></span>
    <Elu.Value placeholder="Set status" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="in_progress">
        <span class="dot" aria-hidden="true"></span>
        <Elu.ItemText>In Progress</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <!-- …more statuses -->
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>

<style>
  /* One rule per status — selects the matching item by value, and
     the trigger when its data-status mirrors that value. */
  .status-select [data-elu-trigger][data-status="in_progress"] .dot,
  .status-select [data-elu-item][data-value="in_progress"] .dot {
    background: oklch(0.78 0.16 85);
  }
</style>

<script>
  // Mirror the selected value onto the trigger so the CSS rule above paints the dot.
  const root = document.getElementById('status');
  const trigger = root.querySelector('[data-elu-trigger]');
  const initial = JSON.parse(root.dataset.valueInitial || '[]')[0];
  if (initial) trigger.dataset.status = initial;
  root.addEventListener('elu:change', (e) => {
    trigger.dataset.status = e.detail.value;
  });
</script>`;
---

<section id="status">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Status select</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">
    Style each item with its <InlineCode>[data-value]</InlineCode> selector, then mirror the active value onto the trigger via <InlineCode>elu:change</InlineCode>. One CSS rule paints both surfaces.
  </p>
  <div class="flex items-center justify-center py-6 px-4 rounded-[6px] bg-[var(--page-demo-bg)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root id="status-select" class="status-select" defaultValue="in_progress">
      <Elu.Trigger>
        <span class="dot" aria-hidden="true"></span>
        <Elu.Value placeholder="Set status" />
      </Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          {statuses.map((s) => (
            <Elu.Item value={s.value}>
              <span class="dot" aria-hidden="true"></span>
              <Elu.ItemText>{s.label}</Elu.ItemText>
              <Elu.ItemIndicator />
            </Elu.Item>
          ))}
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock code={code} lang="astro" />
</section>

<script>
  const root = document.getElementById('status-select');
  if (root) {
    const trigger = root.querySelector<HTMLElement>('[data-elu-trigger]');
    const initial = (JSON.parse((root as HTMLElement).dataset.valueInitial || '[]') as string[])[0];
    if (initial && trigger) trigger.dataset.status = initial;
    root.addEventListener('elu:change', (e) => {
      const detail = (e as CustomEvent).detail as { value: string | string[] };
      const val = Array.isArray(detail.value) ? detail.value[0] : detail.value;
      if (val && trigger) trigger.dataset.status = val;
    });
  }
</script>

<style is:global>
  .status-select {
    --elu-width: 240px;
  }
  .status-select [data-elu-trigger] {
    gap: 8px;
  }
  .status-select [data-elu-item] {
    gap: 8px;
  }
  .status-select .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    background: oklch(0.7 0 0);
    box-shadow: inset 0 0 0 1px oklch(0 0 0 / 0.08);
    transition: background-color 150ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  [data-theme="dark"] .status-select .dot {
    box-shadow: inset 0 0 0 1px oklch(1 0 0 / 0.1);
  }

  .status-select [data-elu-trigger][data-status="backlog"] .dot,
  .status-select [data-elu-item][data-value="backlog"] .dot {
    background: oklch(0.72 0 0);
  }
  .status-select [data-elu-trigger][data-status="todo"] .dot,
  .status-select [data-elu-item][data-value="todo"] .dot {
    background: oklch(0.6 0 0);
  }
  .status-select [data-elu-trigger][data-status="in_progress"] .dot,
  .status-select [data-elu-item][data-value="in_progress"] .dot {
    background: oklch(0.78 0.16 85);
  }
  .status-select [data-elu-trigger][data-status="in_review"] .dot,
  .status-select [data-elu-item][data-value="in_review"] .dot {
    background: oklch(0.62 0.18 295);
  }
  .status-select [data-elu-trigger][data-status="done"] .dot,
  .status-select [data-elu-item][data-value="done"] .dot {
    background: oklch(0.66 0.17 145);
  }
  .status-select [data-elu-trigger][data-status="canceled"] .dot,
  .status-select [data-elu-item][data-value="canceled"] .dot {
    background: oklch(0.62 0.2 25);
  }
</style>

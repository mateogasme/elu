---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';
import InlineCode from './InlineCode.astro';

const astroCode = `---
import { Elu } from '@mgasme/elu';
import '@mgasme/elu/styles.css';
---

<Elu.Root name="fruit" defaultValue="orange">
  <Elu.Trigger>
    <Elu.Value placeholder="Pick a fruit" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="orange">
        <Elu.ItemText>Orange</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="lemon">
        <Elu.ItemText>Lemon</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;

const reactCode = `'use client';
import { Elu } from '@mgasme/elu-react';
import '@mgasme/elu-react/styles.css';

export function FruitSelect() {
  return (
    <Elu.Root name="fruit" defaultValue="orange">
      <Elu.Trigger>
        <Elu.Value placeholder="Pick a fruit" />
      </Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          <Elu.Item value="orange">
            <Elu.ItemText>Orange</Elu.ItemText>
            <Elu.ItemIndicator />
          </Elu.Item>
          <Elu.Item value="lemon">
            <Elu.ItemText>Lemon</Elu.ItemText>
            <Elu.ItemIndicator />
          </Elu.Item>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  );
}`;

const svelteCode = `<script lang="ts">
  import { Elu } from '@mgasme/elu-svelte';
  import '@mgasme/elu-svelte/styles.css';

  let value = 'orange';
</script>

<Elu.Root name="fruit" bind:value>
  <Elu.Trigger>
    <Elu.Value placeholder="Pick a fruit" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="orange">
        <Elu.ItemText>Orange</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="lemon">
        <Elu.ItemText>Lemon</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;

const vueCode = `<script setup lang="ts">
import { Elu } from '@mgasme/elu-vue';
import '@mgasme/elu-vue/styles.css';
</script>

<template>
  <Elu.Root name="fruit" default-value="orange">
    <Elu.Trigger>
      <Elu.Value placeholder="Pick a fruit" />
    </Elu.Trigger>
    <Elu.Content>
      <Elu.Viewport>
        <Elu.Item value="orange">
          <Elu.ItemText>Orange</Elu.ItemText>
          <Elu.ItemIndicator />
        </Elu.Item>
        <Elu.Item value="lemon">
          <Elu.ItemText>Lemon</Elu.ItemText>
          <Elu.ItemIndicator />
        </Elu.Item>
      </Elu.Viewport>
    </Elu.Content>
  </Elu.Root>
</template>`;
---

<section id="usage">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Usage</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">
    Nest the parts inside <InlineCode>Elu.Root</InlineCode>. Keyboard nav, animation, and accessibility come built in.
  </p>
  <div class="flex items-center justify-center py-6 px-4 rounded-[6px] bg-[var(--page-demo-bg)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root name="fruit" defaultValue="orange">
      <Elu.Trigger>
        <Elu.Value placeholder="Pick a fruit" />
      </Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          <Elu.Item value="orange"><Elu.ItemText>Orange</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="lemon"><Elu.ItemText>Lemon</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="grapefruit"><Elu.ItemText>Grapefruit</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock codes={{ astro: astroCode, react: reactCode, vue: vueCode, svelte: svelteCode }} />
</section>

---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';
import InlineCode from './InlineCode.astro';

const astroCode = `<Elu.Root name="country">
  <Elu.Trigger>
    <Elu.Value placeholder="Pick a country" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Search placeholder="Search countries…" />
    <Elu.Viewport>
      <Elu.Item value="ar">
        <Elu.ItemText>Argentina</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="br">
        <Elu.ItemText>Brazil</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
      <Elu.Item value="ca">
        <Elu.ItemText>Canada</Elu.ItemText>
        <Elu.ItemIndicator />
      </Elu.Item>
    </Elu.Viewport>
    <Elu.Empty>No countries match.</Elu.Empty>
  </Elu.Content>
</Elu.Root>`;

const reactCode = `const countries = [
  { value: 'ar', label: 'Argentina' },
  { value: 'br', label: 'Brazil' },
  { value: 'ca', label: 'Canada' },
];

<Elu.Root name="country">
  <Elu.Trigger>
    <Elu.Value placeholder="Pick a country" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Search placeholder="Search countries…" />
    <Elu.Viewport>
      {countries.map((c) => (
        <Elu.Item key={c.value} value={c.value}>
          <Elu.ItemText>{c.label}</Elu.ItemText>
          <Elu.ItemIndicator />
        </Elu.Item>
      ))}
    </Elu.Viewport>
    <Elu.Empty>No countries match.</Elu.Empty>
  </Elu.Content>
</Elu.Root>`;

const vueCode = `<script setup lang="ts">
import { Elu } from '@mgasme/elu-vue';

const countries = [
  { value: 'ar', label: 'Argentina' },
  { value: 'br', label: 'Brazil' },
  { value: 'ca', label: 'Canada' },
];
</script>

<template>
  <Elu.Root name="country">
    <Elu.Trigger>
      <Elu.Value placeholder="Pick a country" />
    </Elu.Trigger>
    <Elu.Content>
      <Elu.Search placeholder="Search countries…" />
      <Elu.Viewport>
        <Elu.Item v-for="c in countries" :key="c.value" :value="c.value">
          <Elu.ItemText>{{ c.label }}</Elu.ItemText>
          <Elu.ItemIndicator />
        </Elu.Item>
      </Elu.Viewport>
      <Elu.Empty>No countries match.</Elu.Empty>
    </Elu.Content>
  </Elu.Root>
</template>`;
---

<section id="searchable">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Searchable</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">Drop in <InlineCode>Elu.Search</InlineCode>. Items filter as you type. Pair with <InlineCode>Elu.Empty</InlineCode> for a no-results message.</p>
  <div class="flex items-center justify-center py-6 px-4 rounded-[6px] bg-[var(--page-demo-bg)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root name="country">
      <Elu.Trigger><Elu.Value placeholder="Pick a country" /></Elu.Trigger>
      <Elu.Content>
        <Elu.Search placeholder="Search countries…" />
        <Elu.Viewport>
          <Elu.Item value="ar"><Elu.ItemText>Argentina</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="br"><Elu.ItemText>Brazil</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="ca"><Elu.ItemText>Canada</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="cl"><Elu.ItemText>Chile</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="co"><Elu.ItemText>Colombia</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="de"><Elu.ItemText>Germany</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="es"><Elu.ItemText>Spain</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="fr"><Elu.ItemText>France</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="jp"><Elu.ItemText>Japan</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="mx"><Elu.ItemText>Mexico</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="uk"><Elu.ItemText>United Kingdom</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="us"><Elu.ItemText>United States</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="uy"><Elu.ItemText>Uruguay</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
        </Elu.Viewport>
        <Elu.Empty>No countries match.</Elu.Empty>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock codes={{ astro: astroCode, react: reactCode, vue: vueCode }} />
</section>

---
import InstallBlock from './InstallBlock.astro';
import InlineCode from './InlineCode.astro';
---

<section id="installation">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Installation</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4" data-fw-block="astro">
    No runtime dependencies. Needs Astro 5+. Works with any Astro project out of the box. One style import in your layout.
  </p>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4" data-fw-block="react">
    No runtime dependencies. Works with React 18 and 19, including Next.js App Router. One style import in your layout.
  </p>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4" data-fw-block="vue">
    No runtime dependencies. Vue 3.3+ with <InlineCode>&lt;script setup&gt;</InlineCode>. Works with Vite and Nuxt. One style import in your entry.
  </p>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4" data-fw-block="svelte">
    No runtime dependencies. Svelte 4 and Svelte 5 (runes-free, works in legacy mode). Drop into any SvelteKit or Vite project. One style import in your entry.
  </p>
  <InstallBlock codes={{ astro: 'npm install @mgasme/elu', react: 'npm install @mgasme/elu-react', vue: 'npm install @mgasme/elu-vue', svelte: 'npm install @mgasme/elu-svelte' }} />
</section>

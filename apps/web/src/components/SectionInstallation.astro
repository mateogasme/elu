---
import InstallBlock from './InstallBlock.astro';
---

<section id="installation">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Installation</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">Zero runtime dependencies. Requires Astro 5 or later. Import styles once in your layout.</p>
  <InstallBlock code="npm install @mgasme/elu" />
</section>

---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';
import InlineCode from './InlineCode.astro';

// Official brand marks from svgl.app
const vercelMark = `<svg viewBox="0 0 256 222" xmlns="http://www.w3.org/2000/svg"><path fill="white" d="m128 0 128 221.705H0z"/></svg>`;
const linearMark = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none"><path fill="white" d="M1.225 61.523c-.222-.949.908-1.546 1.597-.857l36.512 36.512c.69.69.092 1.82-.857 1.597-18.425-4.323-32.93-18.827-37.252-37.252ZM.002 46.889a.99.99 0 0 0 .29.76L52.35 99.71c.201.2.478.307.76.29 2.37-.149 4.695-.46 6.963-.927.765-.157 1.03-1.096.478-1.648L2.576 39.448c-.552-.551-1.491-.286-1.648.479a50.067 50.067 0 0 0-.926 6.962ZM4.21 29.705a.988.988 0 0 0 .208 1.1l64.776 64.776c.289.29.726.375 1.1.208a49.908 49.908 0 0 0 5.185-2.684.981.981 0 0 0 .183-1.54L8.436 24.336a.981.981 0 0 0-1.541.183 49.896 49.896 0 0 0-2.684 5.185Zm8.448-11.631a.986.986 0 0 1-.045-1.354C21.78 6.46 35.111 0 49.952 0 77.592 0 100 22.407 100 50.048c0 14.84-6.46 28.172-16.72 37.338a.986.986 0 0 1-1.354-.045L12.659 18.074Z"/></svg>`;
const raycastMark = `<svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M7 18.079V21L0 14L1.46 12.54L7 18.081V18.079ZM9.921 21H7L14 28L15.46 26.54L9.921 21ZM26.535 15.462L27.996 14L13.996 0L12.538 1.466L18.077 7.004H14.73L10.864 3.146L9.404 4.606L11.809 7.01H10.129V17.876H20.994V16.196L23.399 18.6L24.859 17.14L20.994 13.274V9.927L26.535 15.462ZM7.73 6.276L6.265 7.738L7.833 9.304L9.294 7.844L7.73 6.276ZM20.162 18.708L18.702 20.17L20.268 21.738L21.73 20.276L20.162 18.708ZM4.596 9.41L3.134 10.872L7 14.738V11.815L4.596 9.41ZM16.192 21.006H13.268L17.134 24.872L18.596 23.41L16.192 21.006Z" fill="white"/></svg>`;
const stripeMark = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="100 100 312 312" fill="none"><path fill="white" fill-rule="evenodd" d="m120 392 272-57.683V120l-272 58.357z" clip-rule="evenodd"/></svg>`;
const figmaMark = `<svg viewBox="0 0 54 80" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.333 80C20.693 80 26.667 74.027 26.667 66.667V53.333H13.333C5.973 53.333 0 59.307 0 66.667 0 74.027 5.973 80 13.333 80Z" fill="#0ACF83"/><path d="M0 40C0 32.64 5.973 26.667 13.333 26.667H26.667V53.333H13.333C5.973 53.333 0 47.36 0 40Z" fill="#A259FF"/><path d="M0 13.333C0 5.973 5.973 0 13.333 0H26.667V26.667H13.333C5.973 26.667 0 20.693 0 13.333Z" fill="#F24E1E"/><path d="M26.667 0H40C47.36 0 53.333 5.973 53.333 13.333 53.333 20.693 47.36 26.667 40 26.667H26.667V0Z" fill="#FF7262"/><path d="M53.333 40C53.333 47.36 47.36 53.333 40 53.333 32.64 53.333 26.667 47.36 26.667 40 26.667 32.64 32.64 26.667 40 26.667 47.36 26.667 53.333 32.64 53.333 40Z" fill="#1ABCFE"/></svg>`;

const accounts = [
  { value: 'stripe',  brand: 'stripe',  name: 'Stripe',  plan: 'Enterprise', members: 89,  mark: stripeMark },
  { value: 'vercel',  brand: 'vercel',  name: 'Vercel',  plan: 'Pro',        members: 38,  mark: vercelMark },
  { value: 'linear',  brand: 'linear',  name: 'Linear',  plan: 'Pro',        members: 24,  mark: linearMark },
  { value: 'raycast', brand: 'raycast', name: 'Raycast', plan: 'Free',       members: 6,   mark: raycastMark },
  { value: 'figma',   brand: 'figma',   name: 'Figma',   plan: 'Pro',        members: 31,  mark: figmaMark },
];

const code = `<Elu.Root id="workspace" class="account-switcher" defaultValue="stripe">
  <Elu.Trigger>
    <span class="logo" data-brand="stripe"><!-- official SVG mark --></span>
    <Elu.Value placeholder="Switch workspace" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="stripe" textValue="Stripe">
        <span class="logo" data-brand="stripe">
          <!-- brand SVG mark -->
        </span>
        <span class="meta">
          <span class="title">Stripe</span>
          <span class="sub">89 members · Enterprise</span>
        </span>
        <Elu.ItemIndicator />
      </Elu.Item>
      <!-- …more accounts -->
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>

<script>
  // Mirror selected item's logo into trigger.
  const root = document.getElementById('workspace');
  const triggerLogo = root.querySelector('[data-elu-trigger] .logo');
  root.addEventListener('elu:change', (e) => {
    const src = root.querySelector(
      \`[data-elu-item][data-value="\${e.detail.value}"] .logo\`
    );
    if (!src) return;
    triggerLogo.dataset.brand = src.dataset.brand;
    triggerLogo.innerHTML = src.innerHTML;
  });
</script>`;
---

<section id="custom">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Custom items</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">
    Items and triggers take any markup. Override <InlineCode>--elu-*</InlineCode> variables per
    instance to change width, height, and radius without affecting other selects on the page. Pass
    <InlineCode>textValue</InlineCode> so the trigger and keyboard filter work off plain text.
  </p>
  <div class="flex items-center justify-center py-6 px-4 rounded-[6px] bg-[var(--page-demo-bg)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root id="workspace-switcher" class="account-switcher" defaultValue="stripe">
      <Elu.Trigger>
        <span class="logo" data-brand="stripe" aria-hidden="true" set:html={stripeMark}></span>
        <Elu.Value placeholder="Switch workspace" />
      </Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          {accounts.map((a) => (
            <Elu.Item value={a.value} textValue={a.name}>
              <span class="logo" data-brand={a.brand} aria-hidden="true" set:html={a.mark}></span>
              <span class="meta">
                <span class="title">{a.name}</span>
                <span class="sub">{a.members} {a.members === 1 ? 'member' : 'members'} · {a.plan}</span>
              </span>
              <Elu.ItemIndicator />
            </Elu.Item>
          ))}
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock code={code} lang="astro" />
</section>

<script>
  const root = document.getElementById('workspace-switcher');
  if (root) {
    const triggerLogo = root.querySelector<HTMLElement>('[data-elu-trigger] .logo');
    root.addEventListener('elu:change', (e) => {
      const detail = (e as CustomEvent).detail as { value: string | string[] };
      const val = Array.isArray(detail.value) ? detail.value[0] : detail.value;
      if (!val || !triggerLogo) return;
      const src = root.querySelector<HTMLElement>(`[data-elu-item][data-value="${val}"] .logo`);
      if (!src) return;
      triggerLogo.dataset.brand = src.dataset.brand;
      triggerLogo.innerHTML = src.innerHTML;
    });
  }
</script>

<style is:global>
  .account-switcher {
    --elu-width: 320px;
    --elu-trigger-height: 40px;
    --elu-item-height: 52px;
    --elu-item-padding-x: 8px;
    --elu-radius: 10px;
    --elu-radius-item: 6px;
  }
  .account-switcher [data-elu-trigger] {
    gap: 10px;
    padding: 0 12px 0 8px;
  }
  .account-switcher [data-elu-item] {
    gap: 10px;
  }
  .account-switcher .logo {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 0 1px oklch(1 0 0 / 0.1);
    overflow: hidden;
  }
  .account-switcher [data-elu-item] .logo {
    width: 28px;
    height: 28px;
    border-radius: 6px;
  }
  .account-switcher .logo svg {
    width: 62%;
    height: 62%;
    display: block;
  }
  /* Brand colors */
  .account-switcher .logo[data-brand="stripe"] {
    background: oklch(0.521 0.268 277.431);
  }
  .account-switcher .logo[data-brand="vercel"] {
    background: oklch(0.193 0 0);
  }
  .account-switcher .logo[data-brand="linear"] {
    background: oklch(0.567 0.159 275.206);
  }
  .account-switcher .logo[data-brand="raycast"] {
    background: oklch(0.7 0.191 23.399);
  }
  .account-switcher .logo[data-brand="figma"] {
    background: oklch(0.977 0 0);
    box-shadow: inset 0 0 0 1px oklch(0 0 0 / 0.1);
  }
  .account-switcher .logo[data-brand="figma"] svg {
    width: auto;
    height: 68%;
  }
  .account-switcher .meta {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    line-height: 1.25;
  }
  .account-switcher .title {
    font-size: 13px;
    font-weight: 600;
    color: var(--elu-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .account-switcher .sub {
    font-size: 11px;
    color: var(--elu-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-top: 1px;
  }
</style>

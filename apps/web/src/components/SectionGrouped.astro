---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';
import InlineCode from './InlineCode.astro';

const astroCode = `<Elu.Root name="fruit">
  <Elu.Trigger>
    <Elu.Value placeholder="Pick a fruit" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Group>
        <Elu.GroupLabel>Citrus</Elu.GroupLabel>
        <Elu.Item value="orange">
          <Elu.ItemText>Orange</Elu.ItemText>
          <Elu.ItemIndicator />
        </Elu.Item>
        <Elu.Item value="lemon">
          <Elu.ItemText>Lemon</Elu.ItemText>
          <Elu.ItemIndicator />
        </Elu.Item>
      </Elu.Group>
      <Elu.Group>
        <Elu.GroupLabel>Berries</Elu.GroupLabel>
        <Elu.Item value="strawberry">
          <Elu.ItemText>Strawberry</Elu.ItemText>
          <Elu.ItemIndicator />
        </Elu.Item>
      </Elu.Group>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;

const reactCode = `const groups = [
  { label: 'Citrus',  items: [{ value: 'orange', label: 'Orange' }, { value: 'lemon', label: 'Lemon' }] },
  { label: 'Berries', items: [{ value: 'strawberry', label: 'Strawberry' }] },
];

<Elu.Root name="fruit">
  <Elu.Trigger>
    <Elu.Value placeholder="Pick a fruit" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      {groups.map((g) => (
        <Elu.Group key={g.label}>
          <Elu.GroupLabel>{g.label}</Elu.GroupLabel>
          {g.items.map((it) => (
            <Elu.Item key={it.value} value={it.value}>
              <Elu.ItemText>{it.label}</Elu.ItemText>
              <Elu.ItemIndicator />
            </Elu.Item>
          ))}
        </Elu.Group>
      ))}
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>`;

const vueCode = `<script setup lang="ts">
import { Elu } from '@mgasme/elu-vue';

const groups = [
  { label: 'Citrus',  items: [{ value: 'orange', label: 'Orange' }, { value: 'lemon', label: 'Lemon' }] },
  { label: 'Berries', items: [{ value: 'strawberry', label: 'Strawberry' }] },
];
</script>

<template>
  <Elu.Root name="fruit">
    <Elu.Trigger>
      <Elu.Value placeholder="Pick a fruit" />
    </Elu.Trigger>
    <Elu.Content>
      <Elu.Viewport>
        <Elu.Group v-for="g in groups" :key="g.label">
          <Elu.GroupLabel>{{ g.label }}</Elu.GroupLabel>
          <Elu.Item v-for="it in g.items" :key="it.value" :value="it.value">
            <Elu.ItemText>{{ it.label }}</Elu.ItemText>
            <Elu.ItemIndicator />
          </Elu.Item>
        </Elu.Group>
      </Elu.Viewport>
    </Elu.Content>
  </Elu.Root>
</template>`;
---

<section id="grouped">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Grouped</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">Wrap related items in <InlineCode>Elu.Group</InlineCode> with a sticky <InlineCode>Elu.GroupLabel</InlineCode>. <InlineCode>role="group"</InlineCode> and <InlineCode>aria-labelledby</InlineCode> are set automatically.</p>
  <div class="flex items-center justify-center py-6 px-4 rounded-[6px] bg-[var(--page-demo-bg)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root defaultValue="orange">
      <Elu.Trigger><Elu.Value placeholder="Pick a fruit" /></Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          <Elu.Group>
            <Elu.GroupLabel>Citrus</Elu.GroupLabel>
            <Elu.Item value="orange"><Elu.ItemText>Orange</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
            <Elu.Item value="lemon"><Elu.ItemText>Lemon</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
            <Elu.Item value="grapefruit"><Elu.ItemText>Grapefruit</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          </Elu.Group>
          <Elu.Group>
            <Elu.GroupLabel>Berries</Elu.GroupLabel>
            <Elu.Item value="strawberry"><Elu.ItemText>Strawberry</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
            <Elu.Item value="blueberry"><Elu.ItemText>Blueberry</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
            <Elu.Item value="raspberry"><Elu.ItemText>Raspberry</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          </Elu.Group>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock codes={{ astro: astroCode, react: reactCode, vue: vueCode }} />
</section>

---
import CodeBlock from './CodeBlock.astro';
import InlineCode from './InlineCode.astro';

const code = `/* Scope overrides to a single Root, or apply globally. */
[data-elu-root] {
  --elu-bg: oklch(1 0 0);
  --elu-border: oklch(0.939 0 0);
  --elu-text: oklch(0.204 0 0);
  --elu-radius: 8px;
  --elu-trigger-height: 36px;
  --elu-item-height: 32px;
  --elu-duration-open: 180ms;
  --elu-duration-close: 140ms;
  --elu-easing: cubic-bezier(0.23, 1, 0.32, 1);
}`;
---

<section id="customization">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Customization</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">
    All visual properties are <InlineCode>--elu-*</InlineCode> CSS variables, scoped to <InlineCode>[data-elu-root]</InlineCode>. Set them on the Root, a parent element, or globally.
  </p>
  <CodeBlock code={code} lang="css" />
</section>

---
---

<section id="frameworks">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Frameworks</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-5">
    Astro, React, Vue, and Svelte are ready. Same API, same CSS file — switching is one import change.
  </p>

  <div class="grid grid-cols-2 gap-3">

    <!-- ── Astro ── -->
    <div class="fw-card">
      <div class="fw-card-header">
        <span class="fw-icon" aria-hidden="true">
          <svg viewBox="0 0 85 107" width="13" height="16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M27.59 91.136c-4.834-4.418-6.246-13.703-4.232-20.429 3.492 4.241 8.33 5.584 13.342 6.343 7.737 1.17 15.336.732 22.523-2.804.822-.405 1.582-.943 2.48-1.489.675 1.957.85 3.932.615 5.943-.573 4.896-3.01 8.678-6.885 11.545-1.55 1.147-3.19 2.172-4.79 3.253-4.917 3.323-6.247 7.22-4.4 12.888.044.139.084.277.183.614-2.51-1.124-4.344-2.76-5.742-4.911-1.475-2.27-2.177-4.78-2.214-7.498-.019-1.322-.019-2.656-.197-3.96-.434-3.178-1.926-4.601-4.737-4.683-2.884-.084-5.166 1.699-5.771 4.507-.046.216-.113.429-.18.68l.004.001Z"/>
            <path d="M0 69.587s14.314-6.973 28.668-6.973L39.49 29.12c.405-1.62 1.588-2.72 2.924-2.72 1.335 0 2.518 1.1 2.924 2.72L56.16 62.614c17 0 28.668 6.973 28.668 6.973S60.514 3.352 60.467 3.219C59.769 1.261 58.591 0 57.003 0H27.827c-1.588 0-2.718 1.261-3.464 3.22C24.311 3.35 0 69.586 0 69.586Z"/>
          </svg>
        </span>
        <span class="fw-name">Astro</span>
      </div>
      <code class="fw-pkg">@mgasme/elu</code>
      <ul class="fw-notes">
        <li>Astro 5 or later</li>
        <li>No runtime dependencies</li>
        <li>Ships source directly — Vite transpiles at build</li>
      </ul>
    </div>

    <!-- ── React ── -->
    <div class="fw-card">
      <div class="fw-card-header">
        <span class="fw-icon" aria-hidden="true">
          <svg viewBox="0 0 30 26" width="18" height="16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="15" cy="13" rx="14" ry="4.8" stroke="#58C4DC" stroke-width="1.4"/>
            <ellipse cx="15" cy="13" rx="14" ry="4.8" stroke="#58C4DC" stroke-width="1.4" transform="rotate(60 15 13)"/>
            <ellipse cx="15" cy="13" rx="14" ry="4.8" stroke="#58C4DC" stroke-width="1.4" transform="rotate(120 15 13)"/>
            <circle cx="15" cy="13" r="2.4" fill="#58C4DC"/>
          </svg>
        </span>
        <span class="fw-name">React</span>
      </div>
      <code class="fw-pkg">@mgasme/elu-react</code>
      <ul class="fw-notes">
        <li>React 18 and 19</li>
        <li>Next.js App Router compatible</li>
        <li>All parts include <code class="fw-notes-code">"use client"</code></li>
      </ul>
    </div>

    <!-- ── Vue ── -->
    <div class="fw-card">
      <div class="fw-card-header">
        <span class="fw-icon" aria-hidden="true">
          <svg viewBox="0 0 256 221" width="17" height="15" xmlns="http://www.w3.org/2000/svg">
            <path d="M204.8 0H256L128 220.8 0 0h97.92L128 51.2 157.44 0h47.36Z" fill="#41B883"/>
            <path d="m0 0 128 220.8L256 0h-51.2L128 132.48 50.56 0H0Z" fill="#41B883"/>
            <path d="M50.56 0 128 133.12 204.8 0h-47.36L128 51.2 97.92 0H50.56Z" fill="#35495E"/>
          </svg>
        </span>
        <span class="fw-name">Vue</span>
      </div>
      <code class="fw-pkg">@mgasme/elu-vue</code>
      <ul class="fw-notes">
        <li>Vue 3.3 or later</li>
        <li>No runtime dependencies</li>
        <li>SFCs with <code class="fw-notes-code">&lt;script setup lang="ts"&gt;</code></li>
      </ul>
    </div>

    <!-- ── Svelte ── -->
    <div class="fw-card">
      <div class="fw-card-header">
        <span class="fw-icon" aria-hidden="true">
          <svg viewBox="0 0 256 308" width="10" height="13" xmlns="http://www.w3.org/2000/svg">
            <path d="M239.682 40.707C211.113-.182 154.69-12.301 113.895 13.69L42.247 59.356a82.198 82.198 0 0 0-37.135 55.056 86.566 86.566 0 0 0 8.536 55.576 82.425 82.425 0 0 0-12.296 30.719 87.596 87.596 0 0 0 14.964 66.244c28.574 40.893 84.997 53.007 125.787 27.016l71.648-45.664a82.182 82.182 0 0 0 37.135-55.057 86.601 86.601 0 0 0-8.53-55.577 82.409 82.409 0 0 0 12.29-30.718 87.573 87.573 0 0 0-14.963-66.244" fill="#FF3E00"/>
            <path d="M106.889 270.841c-23.102 6.007-47.497-3.036-61.103-22.648a52.685 52.685 0 0 1-9.003-39.85 49.978 49.978 0 0 1 1.713-6.693l1.35-4.115 3.671 2.697a92.447 92.447 0 0 0 28.036 14.007l2.663.808-.245 2.659a16.067 16.067 0 0 0 2.89 10.656 17.143 17.143 0 0 0 18.397 6.828 15.786 15.786 0 0 0 4.403-1.935l71.67-45.672a14.922 14.922 0 0 0 6.734-9.977 15.923 15.923 0 0 0-2.713-12.011 17.156 17.156 0 0 0-18.404-6.832 15.78 15.78 0 0 0-4.396 1.933l-27.35 17.434a52.298 52.298 0 0 1-14.553 6.391c-23.101 6.007-47.497-3.036-61.101-22.649a52.681 52.681 0 0 1-9.004-39.849 49.428 49.428 0 0 1 22.34-33.114l71.664-45.677a52.218 52.218 0 0 1 14.563-6.398c23.101-6.007 47.497 3.036 61.101 22.648a52.685 52.685 0 0 1 9.004 39.85 50.559 50.559 0 0 1-1.713 6.692l-1.35 4.116-3.67-2.693a92.373 92.373 0 0 0-28.037-14.013l-2.664-.809.246-2.658a16.099 16.099 0 0 0-2.89-10.656 17.143 17.143 0 0 0-18.398-6.828 15.786 15.786 0 0 0-4.402 1.935l-71.67 45.674a14.898 14.898 0 0 0-6.73 9.975 15.9 15.9 0 0 0 2.709 12.012 17.156 17.156 0 0 0 18.404 6.832 15.841 15.841 0 0 0 4.402-1.935l27.345-17.427a52.147 52.147 0 0 1 14.552-6.397c23.101-6.006 47.497 3.037 61.102 22.65a52.681 52.681 0 0 1 9.003 39.848 49.453 49.453 0 0 1-22.34 33.12l-71.664 45.673a52.218 52.218 0 0 1-14.563 6.398" fill="#FFF"/>
          </svg>
        </span>
        <span class="fw-name">Svelte</span>
      </div>
      <code class="fw-pkg">@mgasme/elu-svelte</code>
      <ul class="fw-notes">
        <li>Svelte 4 and Svelte 5</li>
        <li>No runtime dependencies</li>
        <li>Works with SvelteKit out of the box</li>
      </ul>
    </div>

  </div>
</section>

<style>
  .fw-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px;
    border-radius: 8px;
    background: var(--page-card);
    box-shadow: 0 0 0 1px var(--page-border);
  }

  .fw-card-header {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .fw-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 20px;
  }

  .fw-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--page-fg);
    flex: 1;
  }

  .fw-pkg {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--page-fg);
    background: var(--page-card-2);
    border-radius: 4px;
    padding: 4px 7px;
    display: block;
    width: fit-content;
    box-shadow: 0 0 0 1px var(--page-border);
  }

  .fw-notes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .fw-notes li {
    font-size: 12px;
    line-height: 1.4;
    color: var(--page-muted);
    padding-left: 12px;
    position: relative;
  }

  .fw-notes li::before {
    content: "·";
    position: absolute;
    left: 3px;
  }

  .fw-notes-code {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 1px 4px;
    border-radius: 3px;
    background: var(--page-card-2);
    box-shadow: 0 0 0 1px var(--page-border);
  }
</style>

---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';
import FwCode from './FwCode.astro';
import InlineCode from './InlineCode.astro';
const astroSnippets = {
  sm: `<Elu.Root size="sm">…</Elu.Root>`,
  md: `<Elu.Root>…</Elu.Root>`,
  lg: `<Elu.Root size="lg">…</Elu.Root>`,
};
const reactSnippets = {
  sm: `<Elu.Root size="sm">…</Elu.Root>`,
  md: `<Elu.Root>…</Elu.Root>`,
  lg: `<Elu.Root size="lg">…</Elu.Root>`,
};
const vueSnippets = {
  sm: `<Elu.Root size="sm">…</Elu.Root>`,
  md: `<Elu.Root>…</Elu.Root>`,
  lg: `<Elu.Root size="lg">…</Elu.Root>`,
};
---

<section id="sizes">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Sizes</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">Pass <InlineCode>size="sm"</InlineCode> or <InlineCode>size="lg"</InlineCode> to adjust density. <InlineCode>md</InlineCode> is the default.</p>
  <div class="flex flex-wrap gap-2 mb-4 -mx-4 px-4 py-1 relative" data-size-buttons>
    <button class="px-3 py-2 bg-[var(--page-card)] text-[var(--page-fg)] whitespace-nowrap rounded-[6px] text-[13px] font-medium font-[inherit] cursor-pointer border-0 shadow-[0_0_0_1px_var(--page-border)] transition-[background-color,box-shadow] duration-[180ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)] hover:bg-[var(--page-hover)] hover:shadow-[0_0_0_1px_var(--page-border-strong)] data-[active=true]:bg-[var(--page-active)] data-[active=true]:shadow-[0_0_0_1px_var(--page-border-strong)] focus-visible:outline-2 focus-visible:outline-[oklch(0.57_0.211_257.941)] focus-visible:outline-offset-2" type="button" data-size="sm">Small</button>
    <button class="px-3 py-2 bg-[var(--page-card)] text-[var(--page-fg)] whitespace-nowrap rounded-[6px] text-[13px] font-medium font-[inherit] cursor-pointer border-0 shadow-[0_0_0_1px_var(--page-border)] transition-[background-color,box-shadow] duration-[180ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)] hover:bg-[var(--page-hover)] hover:shadow-[0_0_0_1px_var(--page-border-strong)] data-[active=true]:bg-[var(--page-active)] data-[active=true]:shadow-[0_0_0_1px_var(--page-border-strong)] focus-visible:outline-2 focus-visible:outline-[oklch(0.57_0.211_257.941)] focus-visible:outline-offset-2" type="button" data-size="md" data-active="true">Medium</button>
    <button class="px-3 py-2 bg-[var(--page-card)] text-[var(--page-fg)] whitespace-nowrap rounded-[6px] text-[13px] font-medium font-[inherit] cursor-pointer border-0 shadow-[0_0_0_1px_var(--page-border)] transition-[background-color,box-shadow] duration-[180ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)] hover:bg-[var(--page-hover)] hover:shadow-[0_0_0_1px_var(--page-border-strong)] data-[active=true]:bg-[var(--page-active)] data-[active=true]:shadow-[0_0_0_1px_var(--page-border-strong)] focus-visible:outline-2 focus-visible:outline-[oklch(0.57_0.211_257.941)] focus-visible:outline-offset-2" type="button" data-size="lg">Large</button>
  </div>
  <div class="flex items-center justify-center px-4 rounded-[6px] bg-[var(--page-demo-bg)] shadow-[0_0_0_1px_var(--page-border)]" style="height: 120px;">
    <Elu.Root id="size-preview" defaultValue="b">
      <Elu.Trigger><Elu.Value /></Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          <Elu.Item value="a"><Elu.ItemText>Option A</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="b"><Elu.ItemText>Option B</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="c"><Elu.ItemText>Option C</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock copyFromActive="size-code">
    <div data-code-pane data-code-id="sm" data-code-group="size-code" data-framework="astro">
      <FwCode code={astroSnippets.sm} lang="astro" fw="astro" />
    </div>
    <div data-code-pane data-code-id="md" data-code-group="size-code" data-framework="astro" data-active="true">
      <FwCode code={astroSnippets.md} lang="astro" fw="astro" />
    </div>
    <div data-code-pane data-code-id="lg" data-code-group="size-code" data-framework="astro">
      <FwCode code={astroSnippets.lg} lang="astro" fw="astro" />
    </div>
    <div data-code-pane data-code-id="sm" data-code-group="size-code" data-framework="react">
      <FwCode code={reactSnippets.sm} lang="tsx" fw="react" />
    </div>
    <div data-code-pane data-code-id="md" data-code-group="size-code" data-framework="react" data-active="true">
      <FwCode code={reactSnippets.md} lang="tsx" fw="react" />
    </div>
    <div data-code-pane data-code-id="lg" data-code-group="size-code" data-framework="react">
      <FwCode code={reactSnippets.lg} lang="tsx" fw="react" />
    </div>
    <div data-code-pane data-code-id="sm" data-code-group="size-code" data-framework="vue">
      <FwCode code={vueSnippets.sm} lang="html" fw="vue" />
    </div>
    <div data-code-pane data-code-id="md" data-code-group="size-code" data-framework="vue" data-active="true">
      <FwCode code={vueSnippets.md} lang="html" fw="vue" />
    </div>
    <div data-code-pane data-code-id="lg" data-code-group="size-code" data-framework="vue">
      <FwCode code={vueSnippets.lg} lang="html" fw="vue" />
    </div>
  </CodeBlock>
</section>

<script>
  const sizeButtons = document.querySelectorAll<HTMLButtonElement>(
    '[data-size-buttons] [data-size]',
  );
  const sizePreview = document.getElementById('size-preview');
  const sizePanes = document.querySelectorAll<HTMLElement>(
    '[data-code-group="size-code"]',
  );
  sizeButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const size = btn.dataset.size as 'sm' | 'md' | 'lg';
      sizeButtons.forEach((b) =>
        b === btn ? (b.dataset.active = 'true') : delete b.dataset.active,
      );
      if (sizePreview) {
        if (size === 'md') delete sizePreview.dataset.size;
        else sizePreview.dataset.size = size;
      }
      sizePanes.forEach((p) =>
        p.dataset.codeId === size
          ? (p.dataset.active = 'true')
          : delete p.dataset.active,
      );
    });
  });
</script>

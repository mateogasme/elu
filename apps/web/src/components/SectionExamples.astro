<script>
  // ── Workspace switcher ─────────────────────────────────────────────────────
  const wsRoot = document.getElementById('workspace-switcher');
  if (wsRoot) {
    const triggerLogo = wsRoot.querySelector<HTMLElement>('[data-elu-trigger] .logo');
    wsRoot.addEventListener('elu:change', (e) => {
      const detail = (e as CustomEvent).detail as { value: string | string[] };
      const val = Array.isArray(detail.value) ? detail.value[0] : detail.value;
      if (!val || !triggerLogo) return;
      const src = wsRoot.querySelector<HTMLElement>(`[data-elu-item][data-value="${val}"] .logo`);
      if (!src) return;
      triggerLogo.dataset.brand = src.dataset.brand;
      triggerLogo.innerHTML = src.innerHTML;
    });
  }

  // ── Model picker ───────────────────────────────────────────────────────────
  const mdRoot = document.getElementById('model-picker');
  if (mdRoot) {
    const mark = mdRoot.querySelector<HTMLElement>('[data-elu-trigger] .provider-mark');
    const sources: Record<string, string> = {};
    mdRoot.querySelectorAll<HTMLElement>('[data-elu-group-label] .provider-mark').forEach((m) => {
      if (m.dataset.provider) sources[m.dataset.provider] = m.innerHTML;
    });
    mdRoot.addEventListener('elu:change', (e) => {
      const detail = (e as CustomEvent).detail as { value: string | string[] };
      const val = Array.isArray(detail.value) ? detail.value[0] : detail.value;
      if (!val || !mark) return;
      const item = mdRoot.querySelector<HTMLElement>(`[data-elu-item][data-value="${val}"]`);
      const group = item?.closest('[data-elu-group]');
      const provider = group?.querySelector<HTMLElement>('[data-elu-group-label] .provider-mark')?.dataset.provider;
      if (!provider) return;
      mark.dataset.provider = provider;
      mark.innerHTML = sources[provider];
    });
  }

  // ── Assignee picker ────────────────────────────────────────────────────────
  const asRoot = document.getElementById('assignee-picker');
  if (asRoot) {
    const stack = asRoot.querySelector<HTMLElement>('[data-stack]');
    const label = asRoot.querySelector<HTMLElement>('[data-label]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const EASE = 'cubic-bezier(0.2, 0, 0, 1)';
    const ENTER_MS = 180;
    const EXIT_MS = 120;
    const COLLAPSE_PX = 16; // avatar width 22 - overlap 6
    let firstRender = true;
    let labelFlip: Animation | null = null;

    function flipLabel(dx: number, durationMs: number) {
      if (!label || Math.abs(dx) < 0.5) return;
      if (labelFlip) {
        try { labelFlip.cancel(); } catch {}
      }
      labelFlip = label.animate(
        [
          { transform: `translateX(${dx}px)` },
          { transform: 'translateX(0px)' },
        ],
        { duration: durationMs, easing: EASE },
      );
      labelFlip.finished.then(() => { labelFlip = null; }).catch(() => {});
    }

    function updateLabel(values: string[]) {
      if (!label) return;
      if (values.length === 0) {
        label.textContent = 'Assign…';
        label.dataset.empty = 'true';
      } else if (values.length === 1) {
        const nameEl = asRoot!.querySelector<HTMLElement>(`[data-elu-item][data-value="${values[0]}"] .name`);
        label.textContent = nameEl?.textContent ?? '';
        label.dataset.empty = 'false';
      } else {
        label.textContent = `${values.length} assignees`;
        label.dataset.empty = 'false';
      }
    }

    function applyZIndex(values: string[]) {
      if (!stack) return;
      const visible = values.slice(0, 3);
      visible.forEach((id, i) => {
        const el = stack.querySelector<HTMLElement>(`[data-stack-id="${id}"]:not([data-exiting])`);
        if (el) el.style.zIndex = String(visible.length - i);
      });
    }

    function render(values: string[]) {
      if (!stack) return;
      const visible = values.slice(0, 3);
      const visibleSet = new Set(visible);
      const existing = Array.from(stack.querySelectorAll<HTMLElement>('[data-stack-id]:not([data-exiting])'));

      const goingToEmpty = values.length === 0;

      const labelOldRect = !reduce && !firstRender ? label?.getBoundingClientRect() ?? null : null;

      existing.forEach((el) => {
        const id = el.dataset.stackId;
        if (!id || visibleSet.has(id)) return;
        el.dataset.exiting = 'true';
        el.style.pointerEvents = 'none';
        el.style.zIndex = '0';
        if (reduce || firstRender) {
          el.remove();
          return;
        }

        if (goingToEmpty && label) {
          // Single-phase: avatar fades in place (no marginRight collapse)
          // while the label is FLIP-translated from its current X1 to its
          // final X2 (after stack:empty hides the whole stack + 8px gap).
          // At t=EXIT_MS we remove the avatar and cancel the transform in
          // the same JS task — layout shifts label to X2 and transform
          // resets to 0 in lockstep, so visual position stays continuous.
          const before = label.getBoundingClientRect();
          stack.style.display = 'none';
          const after = label.getBoundingClientRect();
          stack.style.display = '';
          const dx = after.left - before.left;
          const anim = el.animate(
            [
              { opacity: 1, transform: 'scale(1)' },
              { opacity: 0, transform: 'scale(0.7)' },
            ],
            { duration: EXIT_MS, easing: EASE, fill: 'forwards' },
          );
          const labelAnim = Math.abs(dx) >= 0.5
            ? label.animate(
                [
                  { transform: 'translateX(0px)' },
                  { transform: `translateX(${dx}px)` },
                ],
                { duration: EXIT_MS, easing: EASE, fill: 'forwards' },
              )
            : null;
          updateLabel(values);
          anim.finished.then(() => {
            el.remove();
            if (labelAnim) labelAnim.cancel();
          }).catch(() => {});
        } else {
          const anim = el.animate(
            [
              { marginRight: '0px', opacity: 1, transform: 'scale(1)' },
              { marginRight: `-${COLLAPSE_PX}px`, opacity: 0, transform: 'scale(0.7)' },
            ],
            { duration: EXIT_MS, easing: EASE, fill: 'forwards' },
          );
          anim.finished
            .then(() => {
              if (!label) { el.remove(); return; }
              const before = label.getBoundingClientRect();
              el.remove();
              const after = label.getBoundingClientRect();
              flipLabel(before.left - after.left, EXIT_MS);
            })
            .catch(() => {});
        }
      });

      // Enter: clone source avatar, append, animate margin-right from
      // collapsed -> 0 so the stack grows smoothly while the avatar fades
      // and scales in over the same period.
      const stillIds = new Set(
        existing
          .filter((el) => el.dataset.stackId && visibleSet.has(el.dataset.stackId!))
          .map((el) => el.dataset.stackId!),
      );
      visible.forEach((id) => {
        if (stillIds.has(id)) return;
        const src = asRoot!.querySelector<HTMLElement>(`[data-elu-item][data-value="${id}"] .avatar`);
        if (!src) return;
        const clone = src.cloneNode(true) as HTMLElement;
        clone.dataset.stackId = id;
        stack.appendChild(clone);
        if (reduce || firstRender) return;
        const anim = clone.animate(
          [
            { marginRight: `-${COLLAPSE_PX}px`, opacity: 0, transform: 'scale(0.6)' },
            { marginRight: '0px', opacity: 1, transform: 'scale(1)' },
          ],
          { duration: ENTER_MS, easing: EASE, fill: 'both' },
        );
        anim.finished
          .then(() => { try { anim.commitStyles(); anim.cancel(); } catch {} })
          .catch(() => {});
      });

      // Sync FLIP: if mutations shifted the label position (e.g. first avatar
      // entering toggled stack from display:none to inline-flex), translate
      // it back to its old visual position and animate to the new one.
      if (label && labelOldRect && !reduce && !firstRender) {
        const labelNewRect = label.getBoundingClientRect();
        flipLabel(labelOldRect.left - labelNewRect.left, ENTER_MS);
      }

      applyZIndex(values);
      // goingToEmpty: updateLabel already called inside the exit branch above.
      if (!goingToEmpty) updateLabel(values);
      firstRender = false;
    }

    const initial = JSON.parse((asRoot as HTMLElement).dataset.valueInitial || '[]') as string[];
    render(initial);
    asRoot.addEventListener('elu:change', (e) => {
      const detail = (e as CustomEvent).detail as { value: string | string[] };
      const values = Array.isArray(detail.value) ? detail.value : (detail.value ? [detail.value] : []);
      render(values);
    });
  }
</script>


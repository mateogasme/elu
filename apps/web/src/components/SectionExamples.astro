const workspaceAstroCode = `<Elu.Root id="workspace" class="account-switcher" defaultValue="stripe">
  <Elu.Trigger>
    <span class="logo" data-brand="stripe">
      <!-- official SVG mark -->
    </span>
    <Elu.Value placeholder="Switch workspace" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Viewport>
      <Elu.Item value="stripe" textValue="Stripe">
        <span class="logo" data-brand="stripe">
          <!-- brand SVG mark -->
        </span>
        <span class="meta">
          <span class="title">Stripe</span>
          <span class="sub">89 members · Enterprise</span>
        </span>
        <Elu.ItemIndicator />
      </Elu.Item>
      <!-- …more accounts -->
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>

<script>
  // Mirror selected item's logo into trigger.
  const root = document.getElementById('workspace');
  const triggerLogo = root.querySelector('[data-elu-trigger] .logo');
  root.addEventListener('elu:change', (e) => {
    const src = root.querySelector(
      \`[data-elu-item][data-value="\${e.detail.value}"] .logo\`
    );
    if (!src) return;
    triggerLogo.dataset.brand = src.dataset.brand;
    triggerLogo.innerHTML = src.innerHTML;
  });
</script>`;

const workspaceReactCode = `'use client';
import { useState } from 'react';
import { Elu } from '@mgasme/elu-react';

const accounts = [
  { value: 'stripe',  name: 'Stripe',  plan: 'Enterprise', members: 89,  mark: <StripeMark /> },
  { value: 'vercel',  name: 'Vercel',  plan: 'Pro',        members: 38,  mark: <VercelMark /> },
  { value: 'linear',  name: 'Linear',  plan: 'Pro',        members: 24,  mark: <LinearMark /> },
];

export function WorkspaceSwitcher() {
  const [value, setValue] = useState('stripe');
  const active = accounts.find((a) => a.value === value)!;

  return (
    <Elu.Root
      className="account-switcher"
      value={value}
      onValueChange={(v) => setValue(v as string)}
    >
      <Elu.Trigger>
        <span className="logo" data-brand={active.value}>{active.mark}</span>
        <Elu.Value placeholder="Switch workspace" />
      </Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          {accounts.map((a) => (
            <Elu.Item key={a.value} value={a.value} textValue={a.name}>
              <span className="logo" data-brand={a.value}>{a.mark}</span>
              <span className="meta">
                <span className="title">{a.name}</span>
                <span className="sub">{a.members} members · {a.plan}</span>
              </span>
              <Elu.ItemIndicator />
            </Elu.Item>
          ))}
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  );
}`;


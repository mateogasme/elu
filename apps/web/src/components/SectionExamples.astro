const assigneeAstroCode = `<Elu.Root id="assignee" class="assignee-picker" multiple defaultValue={['mateo']}>
  <Elu.Trigger>
    <span class="stack" data-stack aria-hidden="true"></span>
    <span class="label" data-label>Assign…</span>
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Search placeholder="Search people…" />
    <Elu.Viewport>
      <Elu.Item value="mateo" textValue="Mateo Gasme">
        <span class="avatar" data-gradient="0">
          <span class="initials">MG</span>
          <span class="online-dot"></span>
        </span>
        <span class="info">
          <span class="name">Mateo Gasme</span>
          <span class="email">mateo@elu.dev</span>
        </span>
        <span class="role">Owner</span>
        <Elu.ItemIndicator />
      </Elu.Item>
      <!-- …more members -->
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>

<script>
  // Rebuild avatar stack + label from selected values.
  const root = document.getElementById('assignee');
  const stack = root.querySelector('[data-stack]');
  const label = root.querySelector('[data-label]');

  function render(values) {
    if (values.length === 0) {
      stack.innerHTML = '';
      label.textContent = 'Assign…';
      return;
    }
    stack.innerHTML = values.slice(0, 3).map((v) => {
      const a = root.querySelector(\`[data-elu-item][data-value="\${v}"] .avatar\`);
      return a ? a.outerHTML : '';
    }).join('');
    label.textContent = values.length === 1
      ? root.querySelector(\`[data-elu-item][data-value="\${values[0]}"] .name\`).textContent
      : \`\${values.length} assignees\`;
  }

  render(JSON.parse(root.dataset.valueInitial || '[]'));
  root.addEventListener('elu:change', (e) => render(e.detail.value || []));
</script>`;

const assigneeReactCode = `'use client';
import { useState } from 'react';
import { Elu } from '@mgasme/elu-react';

const members = [
  { id: 'mateo', name: 'Mateo Gasme',  email: 'mateo@elu.dev',  role: 'Owner',    online: true,  gradient: 0, initials: 'MG' },
  { id: 'ada',   name: 'Ada Lovelace', email: 'ada@elu.dev',    role: 'Engineer', online: true,  gradient: 1, initials: 'AL' },
  // …more members
];

function Avatar({ m }: { m: typeof members[number] }) {
  return (
    <span className="avatar" data-gradient={m.gradient}>
      <span className="initials">{m.initials}</span>
      {m.online && <span className="online-dot" />}
    </span>
  );
}

export function AssigneePicker() {
  const [values, setValues] = useState<string[]>(['mateo']);
  const selected = values.map((v) => members.find((m) => m.id === v)!).filter(Boolean);

  const label =
    values.length === 0 ? 'Assign…'
    : values.length === 1 ? selected[0].name
    : \`\${values.length} assignees\`;

  return (
    <Elu.Root
      className="assignee-picker"
      multiple
      value={values}
      onValueChange={(v) => setValues(v as string[])}
    >
      <Elu.Trigger>
        <span className="stack" aria-hidden="true">
          {selected.slice(0, 3).map((m) => <Avatar key={m.id} m={m} />)}
        </span>
        <span className="label" data-empty={values.length === 0}>{label}</span>
      </Elu.Trigger>
      <Elu.Content>
        <Elu.Search placeholder="Search people…" />
        <Elu.Viewport>
          {members.map((m) => (
            <Elu.Item key={m.id} value={m.id} textValue={\`\${m.name} \${m.email}\`}>
              <Avatar m={m} />
              <span className="info">
                <span className="name">{m.name}</span>
                <span className="email">{m.email}</span>
              </span>
              <span className="role">{m.role}</span>
              <Elu.ItemIndicator />
            </Elu.Item>
          ))}
          <Elu.Empty>No people match.</Elu.Empty>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  );
}`;


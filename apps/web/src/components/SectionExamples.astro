const modelAstroCode = `<Elu.Root id="model" class="model-picker" defaultValue="claude-sonnet-4-6">
  <Elu.Trigger>
    <span class="provider-mark" data-provider="anthropic">
      <!-- provider SVG -->
    </span>
    <Elu.Value placeholder="Select model" />
  </Elu.Trigger>
  <Elu.Content>
    <Elu.Search placeholder="Search models…" />
    <Elu.Viewport>
      <Elu.Group>
        <Elu.GroupLabel>
          <span class="provider-mark" data-provider="anthropic">
            <!-- provider SVG -->
          </span>
          Anthropic
        </Elu.GroupLabel>
        <Elu.Item value="claude-sonnet-4-6" textValue="Claude Sonnet 4.6">
          <span class="info">
            <span class="name">Claude Sonnet 4.6</span>
            <span class="desc">Best for coding</span>
          </span>
          <span class="badges">
            <span class="badge">200K</span>
            <span class="badge">$3.00/M</span>
          </span>
          <Elu.ItemIndicator />
        </Elu.Item>
        <!-- …more models -->
      </Elu.Group>
      <!-- …more providers -->
      <Elu.Empty>No models match.</Elu.Empty>
    </Elu.Viewport>
  </Elu.Content>
</Elu.Root>

<script>
  // Mirror selected model's provider mark into the trigger.
  const root = document.getElementById('model');
  const mark = root.querySelector('[data-elu-trigger] .provider-mark');
  const sources = {};
  root.querySelectorAll('[data-elu-group-label] .provider-mark').forEach((m) => {
    sources[m.dataset.provider] = m.innerHTML;
  });
  root.addEventListener('elu:change', (e) => {
    const item = root.querySelector(\`[data-elu-item][data-value="\${e.detail.value}"]\`);
    const provider = item?.closest('[data-elu-group]')
      ?.querySelector('[data-elu-group-label] .provider-mark')?.dataset.provider;
    if (!provider) return;
    mark.dataset.provider = provider;
    mark.innerHTML = sources[provider];
  });
</script>`;


const assigneeVueCode = `<script setup lang="ts">
import { ref, computed } from 'vue';
import { Elu } from '@mgasme/elu-vue';

const members = [
  { id: 'mateo', name: 'Mateo Gasme',  email: 'mateo@elu.dev', role: 'Owner',    online: true,  gradient: 0, initials: 'MG' },

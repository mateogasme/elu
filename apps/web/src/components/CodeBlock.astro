---
import { Code } from 'astro:components';

interface Props {
  code?: string;
  lang?: string;
  copyFromActive?: string;
  alwaysVisible?: boolean;
  class?: string;
}

const { code, lang, copyFromActive, alwaysVisible, class: className } = Astro.props;
const themes = { light: 'github-light', dark: 'github-dark' } as const;
const hasSlot = Astro.slots.has('default');
---

<div class:list={['cb-wrapper', className]} data-always-visible={alwaysVisible ? '' : undefined}>
  <button
    class="cb-copy"
    type="button"
    aria-label="Copy code"
    data-codeblock-copy
    data-copy={!copyFromActive ? code : undefined}
    data-copy-from-active={copyFromActive}
  >
    <span class="cb-icon-wrap">
      <svg data-icon="copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 17.929H6c-1.105 0-2-.912-2-2.036V5.036C4 3.91 4.895 3 6 3h8c1.105 0 2 .911 2 2.036v1.866m-6 .17h8c1.105 0 2 .91 2 2.035v10.857C20 21.09 19.105 22 18 22h-8c-1.105 0-2-.911-2-2.036V9.107c0-1.124.895-2.036 2-2.036z"/>
      </svg>
      <svg data-icon="check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 6L9 17l-5-5"/>
      </svg>
    </span>
  </button>
  {hasSlot ? <slot /> : code && lang && <Code {code} lang={lang as any} {themes} />}
</div>

<style>
  .cb-wrapper {
    position: relative;
    margin-top: 16px;
    border-radius: 6px;
    border: 1px solid var(--page-border);
    overflow: hidden;
    background: var(--page-card);
  }

  .cb-copy {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 1;
    width: 26px;
    height: 26px;
    border: 1px solid var(--page-border);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--page-bg);
    cursor: pointer;
    opacity: 0;
    color: var(--page-fg);
    padding: 0;
    transition: opacity 200ms;
  }

  .cb-copy:focus-visible {
    opacity: 1;
    outline: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .cb-wrapper:hover .cb-copy {
      opacity: 1;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .cb-copy {
      opacity: 1;
    }
  }

  .cb-wrapper[data-always-visible] .cb-copy {
    opacity: 1;
  }

  .cb-icon-wrap {
    position: relative;
    width: 14px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cb-icon-wrap svg {
    position: absolute;
  }

  .cb-icon-wrap svg[data-icon='check'] {
    opacity: 0;
    transform: scale(0.5);
  }
</style>

<script>
  const DURATION = 150;
  const EASING = 'ease-out';

  function animateOut(el: Element) {
    return el.animate(
      [
        { opacity: 1, transform: 'scale(1)' },
        { opacity: 0, transform: 'scale(0.5)' },
      ],
      { duration: DURATION, easing: EASING, fill: 'forwards' },
    ).finished;
  }

  function animateIn(el: Element) {
    return el.animate(
      [
        { opacity: 0, transform: 'scale(0.5)' },
        { opacity: 1, transform: 'scale(1)' },
      ],
      { duration: DURATION, easing: EASING, fill: 'forwards' },
    ).finished;
  }

  document.querySelectorAll<HTMLButtonElement>('[data-codeblock-copy]').forEach((btn) => {
    if (btn.dataset.copyInited) return;
    btn.dataset.copyInited = 'true';

    const copyIcon = btn.querySelector<SVGElement>('[data-icon="copy"]')!;
    const checkIcon = btn.querySelector<SVGElement>('[data-icon="check"]')!;
    let reset: ReturnType<typeof setTimeout> | null = null;
    let busy = false;

    async function showCheck() {
      if (busy) return;
      busy = true;
      await animateOut(copyIcon);
      await animateIn(checkIcon);
      busy = false;
    }

    async function showCopy() {
      if (busy) return;
      busy = true;
      await animateOut(checkIcon);
      await animateIn(copyIcon);
      busy = false;
    }

    btn.addEventListener('click', async () => {
      const direct = btn.getAttribute('data-copy');
      let payload = direct;
      if (!payload) {
        const group = btn.getAttribute('data-copy-from-active');
        if (group) {
          const active = document.querySelector<HTMLElement>(
            `[data-code-group="${group}"][data-active="true"] pre`,
          );
          payload = active?.textContent ?? '';
        }
      }
      if (!payload) return;

      await navigator.clipboard.writeText(payload);

      if (reset) {
        clearTimeout(reset);
        reset = null;
      }

      await showCheck();
      reset = setTimeout(() => {
        showCopy();
        reset = null;
      }, 2000);
    });
  });
</script>

---
import { Elu } from '@mgasme/elu';
import CodeBlock from './CodeBlock.astro';

const code = `<!-- inherits from any ancestor with data-theme="dark" -->
<html data-theme="dark">…</html>

<!-- or set per instance -->
<Elu.Root theme="dark">…</Elu.Root>`;
---

<section id="theme">
  <h2 class="text-base font-medium text-[var(--page-fg)] mb-2 tracking-[-0.01em]">Theme</h2>
  <p class="text-base leading-[1.55] text-[var(--page-fg)] mb-4">
    The component reads its palette from CSS variables. Toggle the demo
    below. Every surface (page, select, code block) crossfades in
    lockstep.
  </p>
  <div class="flex items-start py-6 px-4 rounded-[6px] bg-[var(--page-card-2)] shadow-[0_0_0_1px_var(--page-border)]">
    <Elu.Root id="theme-select" defaultValue="light">
      <Elu.Trigger><Elu.Value /></Elu.Trigger>
      <Elu.Content>
        <Elu.Viewport>
          <Elu.Item value="light"><Elu.ItemText>Light</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
          <Elu.Item value="dark"><Elu.ItemText>Dark</Elu.ItemText><Elu.ItemIndicator /></Elu.Item>
        </Elu.Viewport>
      </Elu.Content>
    </Elu.Root>
  </div>
  <CodeBlock code={code} lang="astro" />
</section>

<script>
  const STORAGE_KEY = 'elu-theme';
  const TRANSITION_MS = 220;
  const html = document.documentElement;
  const themeSelect = document.getElementById('theme-select') as
    | (HTMLElement & {
        __eluInstance?: {
          setValue: (v: string, opts?: { silent?: boolean }) => void;
        };
      })
    | null;
  let transitionTimer: number | undefined;

  const setTheme = (theme: 'light' | 'dark', animate = true) => {
    if (animate) {
      html.classList.add('theme-transitioning');
      window.clearTimeout(transitionTimer);
      transitionTimer = window.setTimeout(() => {
        html.classList.remove('theme-transitioning');
      }, TRANSITION_MS);
    }
    html.setAttribute('data-theme', theme);
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch {}
  };

  const stored = (() => {
    try {
      return localStorage.getItem(STORAGE_KEY) as 'light' | 'dark' | null;
    } catch {
      return null;
    }
  })();
  const initial: 'light' | 'dark' = stored ?? 'light';
  setTheme(initial, false);
  requestAnimationFrame(() => {
    themeSelect?.__eluInstance?.setValue(initial, { silent: true });
  });

  themeSelect?.addEventListener('elu:change', (e) => {
    const detail = (e as CustomEvent).detail as { value: string | string[] };
    const val = Array.isArray(detail.value) ? detail.value[0] : detail.value;
    if (val === 'light' || val === 'dark') setTheme(val);
  });
</script>

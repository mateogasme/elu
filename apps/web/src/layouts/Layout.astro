---
import '@fontsource-variable/geist';
import '../styles/globals.css';
import '@mgasme/elu/styles.css';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta
      name="description"
      content="Elu — a composable Astro select component. Single, multi, searchable, grouped. Zero runtime dependencies."
    />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121212" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Ctext y='52' font-size='52' font-family='system-ui'%3E%C3%89%3C/text%3E%3C/svg%3E" />
    <title>Elu — composable Astro select</title>
    <script is:inline>
      (function () {
        var stored;
        try { stored = localStorage.getItem('elu-theme'); } catch (_) {}
        document.documentElement.setAttribute('data-theme', stored === 'dark' ? 'dark' : 'light');
      })();
    </script>
  </head>
  <body class="min-h-dvh">
    <slot />
  </body>
</html>
